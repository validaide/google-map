{
    "name": "validaide/google-map",
    "description": "Google Map API v3 integration for PHP 7.2+",
    "keywords": [ "google", "map" ],
    "license": "MIT",
    "authors": [
        {
            "name": "Eric GELOEN",
            "email": "geloen.eric@gmail.com"
        },
        {
            "name": "Mark Bijl",
            "email": "mark.bijl@validaide.com"
        }
    ],
    "require": {
        "php": "^7.2",
        "symfony/event-dispatcher": "^4.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^2.0",
        "symfony/serializer": "^4.3",
        "symfony/console": "^4.3",
        "symfony/finder": "^4.3",
        "symfony/cache": "^4.3",
        "symfony/phpunit-bridge": "^4.3",
        "php-http/cache-plugin": "^1.4",
        "php-http/guzzle6-adapter": "^1.0",
        "phpunit/phpunit": "^8.2",
        "rector/rector": "^0.6.0"
    },
    "autoload": {
        "psr-4": { "Ivory\\GoogleMap\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Ivory\\Tests\\GoogleMap\\": "tests/" }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "3.0-dev"
        }
    }
}
